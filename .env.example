# --- Admin login (HTTP Basic Auth for the dashboard) ---
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-to-something-strong"

# --- Database (Neon / Vercel Postgres pooled connection string) ---
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# --- Cron protection (Vercel sends this automatically to cron routes) ---
CRON_SECRET="run: openssl rand -hex 32"

# --- Google Drive (service account, read-only) ---
# Paste the ENTIRE service-account key JSON on one line.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"potero@your-project.iam.gserviceaccount.com", ...}'
# The ID from your Drive folder URL: drive.google.com/drive/folders/<THIS_PART>
GOOGLE_DRIVE_FOLDER_ID="your-folder-id"

# --- Outstand API ---
OUTSTAND_API_BASE_URL="https://api.outstand.so"
OUTSTAND_API_KEY="your-outstand-api-key"
# Account(s) to publish to. Comma-separated. Each may be a network name
# ("instagram"), a username, or an account id. Required.
OUTSTAND_ACCOUNTS="instagram"
# Publish as an Instagram Story (true) vs a feed post (false). Default true.
OUTSTAND_PUBLISH_AS_STORY="true"
# Only needed if you register the optional delivery webhook in Outstand.
OUTSTAND_WEBHOOK_SECRET="your-outstand-webhook-signing-secret"
