# --- Admin login (HTTP Basic Auth for the dashboard) ---
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-to-something-strong"

# --- Database (Neon / Vercel Postgres pooled connection string) ---
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# --- Vercel Blob (auto-set by Vercel when you add a Blob store) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# --- Cron protection (Vercel sends this automatically to cron routes) ---
CRON_SECRET="run: openssl rand -hex 32"

# --- Outstand API ---
OUTSTAND_API_BASE_URL="https://api.outstand.example"
OUTSTAND_API_KEY="your-outstand-api-key"
# Only needed if you register the optional delivery webhook in Outstand.
OUTSTAND_WEBHOOK_SECRET="run: openssl rand -hex 32"
