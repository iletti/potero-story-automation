# Dashboard login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Vercel Cron authorization.
CRON_SECRET=

# Google Drive content source.
GOOGLE_DRIVE_FOLDER_ID=15H2jnp-Jmg123_KNsUdhIjj-aYU5T6K8
GOOGLE_SERVICE_ACCOUNT_JSON=

# Outstand API.
OUTSTAND_API_BASE_URL=https://api.outstand.so
OUTSTAND_API_KEY=

# Comma-separated Outstand account selectors. Use network names when possible.
# For opaque ids/usernames, prefix with the channel so story overrides can be
# inferred while only the selector after ":" is sent to Outstand.
OUTSTAND_ACCOUNTS=instagram,facebook
# OUTSTAND_ACCOUNTS=instagram:NZOJa,facebook:<facebook-account-id>

# Story publishing is enabled by default. Set false only for feed posts.
OUTSTAND_PUBLISH_AS_STORY=true

# Optional when OUTSTAND_ACCOUNTS uses network names or network-prefixed
# selectors. Required when OUTSTAND_ACCOUNTS uses unprefixed ids/usernames and
# the app cannot infer the channels.
OUTSTAND_STORY_CHANNELS=instagram,facebook

# Optional JSON platform overrides for story-capable channels without a built-in
# override, or to replace a built-in override if Outstand changes a platform.
# Custom override keys can also be used as OUTSTAND_ACCOUNTS prefixes, for
# example custom:acct_123 when this JSON contains {"custom":{...}}.
OUTSTAND_STORY_CONFIG_JSON=

# Validate story-channel env without publishing:
#   npm run outstand:story-config

# Optional delivery webhook signature secret.
OUTSTAND_WEBHOOK_SECRET=

# Provided by the Vercel Neon integration in production.
DATABASE_URL=
